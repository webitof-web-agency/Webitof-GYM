# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
PORT=8080
NODE_ENV=development
BACKEND_URL=http://localhost:8080

# ─────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────
DATABASE_URL=mongodb://localhost:27017/gymstick

# ─────────────────────────────────────────
# JWT / Auth
# ─────────────────────────────────────────
SECRET=your_random_secret_here
JWT_EXPIRE_IN=24h
JWT_EXPIRE_IN_REMEMBER_ME=168h

# ─────────────────────────────────────────
# AWS S3  (optional — only needed when storage.provider = 's3')
# ─────────────────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=
AWS_REGION=
